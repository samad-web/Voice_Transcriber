# ── Database / cache / queue / storage (matches docker-compose.yml) ──────────
# Admin/owner connection (migrations). Host port 5433 — native Postgres owns 5432.
DATABASE_URL=postgresql://aura:aura_dev_password@localhost:5433/callintel
# Runtime connection — non-superuser role so RLS is enforced.
APP_DATABASE_URL=postgresql://aura_app:aura_app_password@localhost:5433/callintel
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://aura:aura_dev_password@localhost:5672
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET=aura-recordings
S3_ACCESS_KEY_ID=aura_minio
S3_SECRET_ACCESS_KEY=aura_minio_password

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
# Dev-only admin auth for platform endpoints until OIDC lands
ADMIN_API_KEY=dev-admin-key
JWT_SECRET=replace-with-a-long-random-secret
DEVICE_JWT_TTL_SECONDS=900

# ── ASR + analyze provider ───────────────────────────────────────────────────
# Pipeline precedence: ASR_STUB/ANALYZE_STUB > GEMINI. Gemini transcribes and
# diarizes in one call, then labels those segments during analyze.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_ASR_MODEL=gemini-3.5-flash
GEMINI_ANALYZE_MODEL=gemini-3.5-flash
#
# Dev-only: run pipeline stages without any provider (clearly-labeled stub output).
ASR_STUB=0
ANALYZE_STUB=0

# ── Model provider layer (analyze stage fallbacks; leave blank if unused) ────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Web app ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
