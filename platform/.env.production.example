# Production environment for docker-compose.prod.yml.
#
#   cp .env.production.example .env.production
#   chmod 600 .env.production          # it holds every credential the stack has
#
# This file is read TWICE: `env_file:` injects it into the containers, and
# `--env-file .env.production` supplies the ${VAR} substitutions in the compose
# file. Always pass --env-file.
#
# Generate secrets with:  openssl rand -base64 36 | tr -d '/+=' | head -c 40

# ── Domains (must already point at this server) ──────────────────────────────
APP_DOMAIN=app.example.com
STORAGE_DOMAIN=storage.example.com
ACME_EMAIL=ops@example.com

# ── Database: Supabase ───────────────────────────────────────────────────────
# Both URLs come from the Supabase dashboard → Project Settings → Database.
# Use the SESSION POOLER (port 5432) or the direct connection; the transaction
# pooler on 6543 also works because every tenant query runs inside an explicit
# transaction — but session mode is the safe default.
#
# Owner connection: migrations, role bootstrap, and the handful of pre-tenant
# admin flows. This is Supabase's `postgres` user.
DATABASE_URL=postgresql://postgres.PROJECTREF:SUPABASE_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
#
# Runtime connection: the NON-superuser role created by 0001 and given its real
# password by `node packages/db/bootstrap-role.js`. RLS only binds because this
# role is neither the table owner nor BYPASSRLS — never point this at postgres.
# Over the pooler the username is <role>.<project-ref>.
APP_DATABASE_URL=postgresql://aura_app.PROJECTREF:APP_DB_PASSWORD_VALUE@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
#
# Read by bootstrap-role.js only. Must be >=24 chars, alphanumeric plus _-.~!@#%^*+=
# and must match the password embedded in APP_DATABASE_URL above.
APP_DB_PASSWORD=replace-with-a-long-random-password
#
# TLS is inferred from the host (managed => on, localhost => off). Point
# DB_SSL_CA at Supabase's CA bundle to upgrade from encrypted to verified.
# DB_SSL_CA=/etc/ssl/supabase/prod-ca-2021.crt

# ── Queue / cache (local to the box, never published) ────────────────────────
RABBITMQ_USER=aura
RABBITMQ_PASSWORD=replace-with-a-long-random-password
RABBITMQ_URL=amqp://aura:replace-with-a-long-random-password@rabbitmq:5672
REDIS_URL=redis://redis:6379

# ── Object storage (MinIO on this box, fronted by STORAGE_DOMAIN) ────────────
S3_ACCESS_KEY_ID=aura-prod-access-key
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-password
S3_BUCKET=aura-recordings
S3_REGION=ap-south-1
# Internal: what the API and worker use to read/write objects. Container DNS,
# no TLS, no proxy hop.
S3_ENDPOINT=http://minio:9000
# Public: ONLY used to presign the upload URLs handed to phones. Must equal
# https://$STORAGE_DOMAIN — SigV4 signs the Host, so a mismatch means every
# device upload fails with SignatureDoesNotMatch.
S3_PUBLIC_ENDPOINT=https://storage.example.com

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
# Browser origin allowed by CORS — the console is served from the same domain.
WEB_ORIGIN=https://app.example.com
# Platform-operator key for /v1/admin/* and the enrollment QR flow. Rotate it
# and every provisioning script has to be updated: treat it as a root password.
ADMIN_API_KEY=replace-with-a-long-random-key
# Signs device JWTs. Rotating it forces every phone to re-enroll.
JWT_SECRET=replace-with-a-long-random-secret
DEVICE_JWT_TTL_SECONDS=900

# ── ASR + analyze provider ───────────────────────────────────────────────────
# Precedence in the pipeline: ASR_STUB/ANALYZE_STUB > GEMINI.
GEMINI_API_KEY=replace-with-your-gemini-key
GEMINI_ASR_MODEL=gemini-3.5-flash
GEMINI_ANALYZE_MODEL=gemini-3.5-flash

# Stubs must be OFF in production — they write clearly-fake transcripts.
ASR_STUB=0
ANALYZE_STUB=0

# ── Web console ──────────────────────────────────────────────────────────────
# Baked into the client bundle at image build time (see docker/web.Dockerfile).
NEXT_PUBLIC_API_URL=https://app.example.com

# ── Console sign-in: Supabase Auth ───────────────────────────────────────────
# Same Supabase project as DATABASE_URL above. Both values come from
# Project Settings → API and are also baked in at image build time.
#
# The anon key is designed to be public — it identifies the project to the auth
# server and grants nothing on its own. Never put the service_role key here.
#
# With either value blank the console runs unauthenticated: /login says auth is
# not configured and the middleware gate is inert. Set both in production.
#
# Supabase dashboard checklist:
#   Authentication → Providers → Email: enabled, "Confirm email" as you prefer
#   Authentication → Providers → Email: DISABLE "Allow new users to sign up"
#     (the console has no signup form, but the endpoint stays open otherwise)
#   Authentication → URL Configuration → Site URL: https://app.example.com
#   Authentication → Users → Add user: create the operator account
NEXT_PUBLIC_SUPABASE_URL=https://PROJECTREF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
# Server components reach the API over the compose network instead.
API_URL=http://api:4000
#
# The console's tenant-scoped pages (dashboard, calls, agents, search, usage,
# team, api-keys, crm) still resolve their org from this variable rather than
# from the signed-in session — /instances is the only multi-tenant view. On a
# fresh production database the seeded dev org does NOT exist, so leaving the
# default here makes those pages render empty. Set it to the org id of the
# customer you actually operate.
# The POST /v1/admin/tenants response in §4 gives you both ids.
DEV_ORG_ID=00000000-0000-0000-0000-000000000000
DEV_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
