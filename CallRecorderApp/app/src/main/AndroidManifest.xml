<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Platform enrollment + config sync (activation gate) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Scan the activation QR (instance id + admin key) on the admin screen -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Core capture -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Foreground service to survive backgrounding while recording (Android 14 granular type) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Reading the OEM dialer's own call recordings (Samsung "Auto record calls", MIUI, …).
         Those files are BOTH-ends audio the system dialer captured from the modem, which a
         normal app can't do itself — so we ingest them instead. MANAGE_EXTERNAL_STORAGE is
         needed to read arbitrary OEM folders on API 30+; READ_MEDIA_AUDIO/READ_EXTERNAL_STORAGE
         covers the MediaStore route. (All-files access is Play-restricted; fine when sideloaded.) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Call detection / metadata (optional; request at runtime, degrade gracefully) -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Needed so EXTRA_INCOMING_NUMBER is populated (the number becomes the recording name) -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <application
        android:name=".App"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Admin-only device activation (hidden entry: long-press toolbar title) -->
        <activity
            android:name=".ui.AdminActivationActivity"
            android:exported="false" />

        <!-- Discovery tool: locates the OEM dialer's call-recording folder on this handset
             and proves we can read it (the prerequisite for ingesting both-ends audio). -->
        <activity
            android:name=".ui.RecordingsScannerActivity"
            android:exported="false" />

        <!-- Full-screen QR scanner (Paytm-style viewfinder) for reading the activation QR -->
        <activity
            android:name=".ui.scanner.QrScannerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />


        <!-- The "eyes and ears": detects which call app is foreground and reads caller info.
             This is the clean-room analogue of Cube ACR's separate helper app.
             Kept IN this app (local dispatch) instead of a second signed APK. -->
        <service
            android:name=".service.CallAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- The "hands": owns the AudioRecord capture + encoding, runs as a foreground service. -->
        <service
            android:name=".service.RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Phone-call state (native cellular calls) -->
        <receiver
            android:name=".service.PhoneStateReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Lets us hand recording files to other apps (share sheet) via a content:// URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
