{"nodes": [{"id": "architecture_callrecorderapp", "label": "CallRecorderApp (Android call recorder + transcriber)", "file_type": "document", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single-module Kotlin app, deliberately transparent and owner-operated: persistent recording notification, no hidden icon, nothing leaves the device."}, {"id": "architecture_cleanroomreimplementation", "label": "Clean-room reimplementation policy", "file_type": "rationale", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Architecture ideas were learned from Cube ACR's decompiled structure but no vendor code was copied; all code and data are original. Never copy vendor code and never patch Cube ACR's billing."}, {"id": "architecture_cubeacr", "label": "Cube ACR (com.catalinagroup.callrecorder)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_phonestatereceiver", "label": "PhoneStateReceiver (cellular call detection)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/service/PhoneStateReceiver.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Starts on OFFHOOK rather than RINGING so unanswered calls are never recorded; receiver instances are short-lived so cross-broadcast state lives in @Volatile companion fields."}, {"id": "architecture_callaccessibilityservice", "label": "CallAccessibilityService (VoIP call-screen detection)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/service/CallAccessibilityService.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Requires both a known messenger package and a call-screen-looking window (exact activity match or voip/webrtc/incall class-name hint) so detection survives activity renames; ignores transient overlays so multitasking does not cut the recording."}, {"id": "architecture_recordingservice", "label": "RecordingService (foreground orchestration)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/service/RecordingService.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only component that touches the capture pipeline; foregroundServiceType=microphone for Android 14 granular types; stopSelf() is deferred until the DB write completes because stopping earlier cancels the coroutine scope and loses the recording."}, {"id": "architecture_sourceregistry", "label": "SourceRegistry (declarative call sources)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/recordings/SourceRegistry.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Holds the BUILT_IN list plus package/activity index maps so adding support for a new messenger is one list entry with no code changes anywhere else."}, {"id": "architecture_callsource", "label": "CallSource (call source data class)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/recordings/CallSource.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_audiocapturer", "label": "AudioCapturer (AudioRecord capture engine)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/capture/AudioCapturer.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "44.1 kHz 16-bit mono PCM on a dedicated thread; exposes the winning source name so per-device capture behaviour can be diagnosed empirically."}, {"id": "architecture_captureprofile", "label": "CaptureProfile (PHONE / VOIP audio-source priority)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/capture/CaptureProfile.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "PHONE orders VOICE_CALL \u2192 VOICE_RECOGNITION \u2192 VOICE_COMMUNICATION \u2192 MIC because VOICE_CALL captures both ends only where the OEM permits; VOIP is MIC-only because the messenger holds the mic exclusively."}, {"id": "architecture_capturesettings", "label": "CaptureSettings (SharedPreferences capture knobs)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/capture/CaptureSettings.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A pinned phone audio source is tried first but the rest of the profile remains as fallback, so a bad pin can never abort recording."}, {"id": "architecture_bluetoothscocontroller", "label": "BluetoothScoController (SCO routing)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SCO does not carry the VOICE_CALL modem stream, so with a BT headset the capturer probes VOICE_COMMUNICATION-family sources instead. Best-effort and device-dependent."}, {"id": "architecture_aacencoder", "label": "AacEncoder (PCM \u2192 AAC/.m4a)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/capture/AacEncoder.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hardened for correctness: never drops PCM (waits for codec input buffers), monotonic timestamps from a cumulative sample counter, muxer track added exactly once, bounded EOS drain, exactly-once release. Single-threaded by contract."}, {"id": "architecture_autoprobe", "label": "Audio-source auto-probe", "file_type": "rationale", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tries each source in profile order and skips any that fails to construct, initialize, or reach RECORDSTATE_RECORDING; exists because which source works is empirical per device."}, {"id": "architecture_silencedetection", "label": "Silence detection & discard-empty policy", "file_type": "rationale", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A cheap sparse scan flips capturedAudio on the first non-silent sample; blocked capture is digital zero, so an all-silent file is deleted and the user notified instead of saving a junk row."}, {"id": "architecture_recordingdatabase", "label": "RecordingDatabase (Room singleton)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/storage/RecordingDatabase.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_recordingentity", "label": "RecordingEntity (Room row)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/storage/RecordingEntity.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stores the winning audio source per recording and already carries a transcript slot so the transcription backend can be wired later without a schema migration."}, {"id": "architecture_recordingdao", "label": "RecordingDao", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/storage/RecordingDao.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_calllogreader", "label": "CallLogReader (call-log enrichment)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The service waits ~1.2 s after stop for the system call-log row to appear before enriching name, number and direction."}, {"id": "architecture_recordingnaming", "label": "RecordingNaming (readable file rename)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_externalfilesstorage", "label": "App-external recordings storage + FileProvider", "file_type": "rationale", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Audio lives under getExternalFilesDir()/recordings/ so no broad storage permission is needed; files reach other apps only through the manifest-declared FileProvider."}, {"id": "architecture_mainactivity", "label": "MainActivity (recordings list + player UI)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/ui/MainActivity.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_recordingsviewmodel", "label": "RecordingsViewModel", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/ui/RecordingsViewModel.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_recordingsadapter", "label": "RecordingsAdapter", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/ui/RecordingsAdapter.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_transcriber", "label": "Transcriber interface (pluggable transcription)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": "app/src/main/kotlin/com/voicetranscriber/callrecorder/transcription/Transcriber.kt", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One-method suspend interface with a global Transcriber.active slot; the on-device (Whisper/Vosk) vs cloud STT decision is deliberately deferred because the rest of the pipeline only ever talks to this interface."}, {"id": "architecture_nooptranscriber", "label": "NoopTranscriber (placeholder implementation)", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_transparencyguardrail", "label": "Transparency guardrail (non-negotiable)", "file_type": "rationale", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ongoing recording notification, no covert operation, no exfiltration. Call recording is consent-regulated and the user is responsible for legality; a consent-announcement tone hook is stubbed in RecordingService."}, {"id": "architecture_voipmicexclusivity", "label": "OS mic-exclusivity wall for VoIP capture", "file_type": "rationale", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "On modern Android the messenger holds the mic exclusively and the OS blocks concurrent capture, yielding digital silence. This is an OS wall for non-root apps \u2014 detect, discard, notify, and do not reinvest."}, {"id": "architecture_sideloadonly", "label": "Sideload-only distribution constraint", "file_type": "rationale", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Google Play bans call recording via the accessibility API, so the accessibility detection path makes the app sideload-only by design."}, {"id": "architecture_cellularcallflow", "label": "Cellular call recording flow", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_voipcallflow", "label": "VoIP call recording flow", "file_type": "concept", "source_file": "ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "architecture_callrecorderapp", "target": "architecture_cleanroomreimplementation", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_cleanroomreimplementation", "target": "architecture_cubeacr", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_phonestatereceiver", "target": "architecture_recordingservice", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_callaccessibilityservice", "target": "architecture_recordingservice", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "archit