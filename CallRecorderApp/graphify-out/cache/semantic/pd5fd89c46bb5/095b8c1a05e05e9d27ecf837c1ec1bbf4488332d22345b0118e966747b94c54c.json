ettings", "relation": "calls", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_recordingsadapter", "target": "architecture_recordingentity", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_nooptranscriber", "target": "architecture_transcriber", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_transcriber", "target": "architecture_recordingentity", "relation": "shares_data_with", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_cellularcallflow", "target": "architecture_phonestatereceiver", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_cellularcallflow", "target": "architecture_calllogreader", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_voipcallflow", "target": "architecture_callaccessibilityservice", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "architecture_voipcallflow", "target": "architecture_silencedetection", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ARCHITECTURE.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "capture_pipeline_components", "label": "Audio capture pipeline components", "nodes": ["architecture_audiocapturer", "architecture_capturepr